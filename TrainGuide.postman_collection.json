        },
        {
          "name": "DELETE /job/{workout_id}/ — удалить задание",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{WORKOUT}}/job/999/", "host": ["{{WORKOUT}}"], "path": ["job", "999", ""] }
          }
        }
      ]
