    {
      "name": "🏋️ workout-service (8001)",
      "description": "Генерация тренировок через Claude API. Порт 8001.",
      "item": [
        {
          "name": "GET / — статус сервиса",
          "request": {
            "method": "GET",
            "url": { "raw": "{{WORKOUT}}/", "host": ["{{WORKOUT}}"], "path": [""] }
          }
        },
        {
          "name": "POST /generate/ — сгенерировать тренировку (синхронно)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{WORKOUT}}/generate/", "host": ["{{WORKOUT}}"], "path": ["generate", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workout_id\": 999,\n  \"user_id\": 1,\n  \"form_data\": {\n    \"goal\": \"похудение\",\n    \"level\": \"начинающий\",\n    \"days_per_week\": 3,\n    \"equipment\": \"нет оборудования\",\n    \"duration_minutes\": 40\n  }\n}"
            }
          }
        },
        {
          "name": "GET /job/{workout_id}/ — статус задания",
          "request": {
            "method": "GET",
            "url": { "raw": "{{WORKOUT}}/job/999/", "host": ["{{WORKOUT}}"], "path": ["job", "999", ""] }
          }
        },
        {
          "name": "GET /jobs/ — список всех заданий",
          "request": {
            "method": "GET",
            "url": { "raw": "{{WORKOUT}}/jobs/", "host": ["{{WORKOUT}}"], "path": ["jobs", ""] }
          }
        },
        {
          "name": "GET /jobs/?status=done — только готовые",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{WORKOUT}}/jobs/?status=done",
              "host": ["{{WORKOUT}}"],
              "path": ["jobs", ""],
              "query": [{ "key": "status", "value": "done" }]
            }
          }
        },
        {
          "name": "GET /queue/info/ — состояние Redis очередей",
          "request": {
            "method": "GET",
            "url": { "raw": "{{WORKOUT}}/queue/info/", "host": ["{{WORKOUT}}"], "path": ["queue", "info", ""] }
          }
        },
        {
          "name": "POST /queue/push/ — добавить задание в Redis вручную",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{WORKOUT}}/queue/push/", "host": ["{{WORKOUT}}"], "path": ["queue", "push", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workout_id\": 777,\n  \"user_id\": 2,\n  \"prompt\": \"Составь тренировку на 30 минут без оборудования для начинающего\"\n}"
